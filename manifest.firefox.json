{
  "manifest_version": 3,
  "name": "Flux",
  "version": "2.2",
  "browser_specific_settings": {
    "gecko": {
      "id": "flux@satya-nayak.dev",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["activeTab", "storage", "alarms", "tabs"],
  "icons": {
    "16": "assets/Flux transparent-16x.png",
    "32": "assets/Flux transparent-32x.png",
    "48": "assets/Flux transparent-48x.png",
    "128": "assets/Flux transparent-128x.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/Flux transparent-16x.png",
      "32": "assets/Flux transparent-32x.png",
      "48": "assets/Flux transparent-48x.png",
      "128": "assets/Flux transparent-128x.png"
    }
  },
  "host_permissions": [
    "https://cdn.jsdelivr.net/*",
    "https://latest.currency-api.pages.dev/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
