{
  "manifest_version": 3,
  "name": "USD to INR Converter",
  "version": "2.1",
  "description": "Converts US Dollar amounts to Indian Rupees on any webpage with per-site controls.",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "host_permissions": [
    "https://cdn.jsdelivr.net/*",
    "https://latest.currency-api.pages.dev/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}