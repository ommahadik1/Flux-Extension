{
  "manifest_version": 3,
  "name": "Flux",
  "version": "2.1",
  "description": "A modern, fluid currency converter that seamlessly localizes prices on any webpage with real-time global exchange rates.",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "Flux transparent-16x.png",
    "32": "Flux transparent-32x.png",
    "48": "Flux transparent-48x.png",
    "128": "Flux transparent-128x.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "Flux transparent-16x.png",
      "32": "Flux transparent-32x.png",
      "48": "Flux transparent-48x.png",
      "128": "Flux transparent-128x.png"
    }
  },
  "host_permissions": [
    "https://cdn.jsdelivr.net/*",
    "https://latest.currency-api.pages.dev/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}